{
  "name": "ipo-advisor-desktop",
  "private": true,
  "version": "0.7.0",
  "description": "Electron shell for IPO Advisor — spawns the Python FastAPI engine as a sidecar, health-gates it, and hosts the PWA as a native Windows app.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json && electron .",
    "start": "electron .",
    "selftest": "tsc -p tsconfig.json && node dist/sidecar.js",
    "dist": "tsc -p tsconfig.json && electron-builder --win --publish never"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.ipoadvisor.app",
    "productName": "IPO Advisor",
    "artifactName": "IPO-Advisor-Setup-${version}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "splash.html"
    ],
    "extraResources": [
      { "from": "../pwa/dist", "to": "pwa" },
      { "from": "../../../../packaging/dist/ipo-engine", "to": "engine" },
      { "from": "build/icon.ico", "to": "icon.ico" }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "sign": "./sign-noop.cjs"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "IPO Advisor",
      "uninstallDisplayName": "IPO Advisor"
    },
    "appx": {
      "identityName": "IPOAdvisorTest.Sideload",
      "publisher": "CN=IPOAdvisorTest",
      "publisherDisplayName": "IPO Advisor",
      "applicationId": "IPOAdvisor",
      "displayName": "IPO Advisor",
      "backgroundColor": "#0a0d12",
      "languages": [
        "en-US"
      ]
    }
  }
}
